# Regenerate with:  vhs assets/demo.tape
# Records the synthetic `phototrips --demo` (no real photos / home — safe to share).
Output assets/demo.gif

Set FontSize 18
Set Width 1200
Set Height 560
Set Theme "Dracula"
Set Padding 24
Set TypingSpeed 55ms

Sleep 600ms
Type "phototrips --demo"
Sleep 700ms
Enter
Sleep 3500ms
